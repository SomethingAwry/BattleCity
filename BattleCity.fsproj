<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFramework>net8.0</TargetFramework>
        <OutputType>WinExe</OutputType>
    </PropertyGroup>
    <ItemGroup>
        <AvaloniaResource Include="Assets/**" />
        <Compile Include="Infrastructure/PropertyChangedBase.fs" />
        <None Include="Infrastructure/CellToScreenConverter.fs" />
        <None Include="Infrastructure/DirectionToMatrixConverter.fs" />
        <None Include="Infrastructure/TerrainTileConverter.fs" />
        <None Include="Infrastructure/ZIndexConverter.fs" />
        <Compile Include="Keyboard.fs" />
        <Compile Include="Model/GameBase.fs" />
        <Compile Include="Model/GameObject.fs" />
        <Compile Include="Model/TerrainTile.fs" />
        <Compile Include="Model/Facing.fs" />
        <Compile Include="Model/Apple.fs" />
        <Compile Include="Model/CellLocation.fs" />
        <Compile Include="Model/MovingGameObject.fs" />
        <Compile Include="Model/Tank.fs" />
        <Compile Include="Model/Player.fs" />
        <Compile Include="Model/GameField.fs" />
        <Compile Include="Model/Game.fs" />
        <Compile Include="MainWindow.axaml.fs" />
        <Compile Include="App.axaml.fs" />
        <Compile Include="Program.fs" />
        <PackageReference Include="Avalonia" Version="11.1.3" />
        <PackageReference Include="Avalonia.Desktop" Version="11.1.3" />
        <PackageReference Include="Avalonia.Themes.Fluent" Version="11.1.3" />
        <PackageReference Condition="'$(Configuration)' == 'Debug'" Include="Avalonia.Diagnostics" Version="11.1.3" />
    </ItemGroup>
</Project>
